<section class="hero-section">
  <div class="hero-bg"></div>

  <div class="container-fluid hero-inner">
    <div class="row align-items-center gx-2">

      <!-- Left Content -->
      <div class="col-md-8 col-12">
        <div class="right-side-section me-md-5 me-0 ms-md-4 ms-0 px-3 px-md-0">

          <div class="logo-wrapper">
            <div class="logo" style="background-image: url('/images/logo.jpeg');"></div>
          </div>

          <h1 class="display-6 hero-title d-inline-block mb-4">
            <span class="highlight-pill px-3 py-2">Detroit residential roofing services</span>
          </h1>

          <h3 class="blue-text bg-white ps-3 pe-3 pe-md-5 rounded py-2">
            Lorem Ipsum is simply dummy text of the printing and typesetting industry.
            Lorem Ipsum has been the industry's standard
          </h3>

        </div>
      </div>

      <!-- Right Form -->
      <div class="col-md-4 col-12 mt-4 mt-md-0">
        <div class="form-container">
          <div class="appointment-card p-4">
            <h5 class="text-center mb-1">Book Your</h5>
            <div class="text-center mb-3">
              <span class="appointment-pill d-inline-block">Appointment Now</span>
            </div>
            <form>
              <div class="row g-2">
                <div class="col-6">
                  <input class="form-control rounded-input" placeholder="First Name *" />
                </div>
                <div class="col-6">
                  <input class="form-control rounded-input" placeholder="Last Name *" />
                </div>
              </div>
              <div class="row g-2 mt-2">
                <div class="col-6">
                  <input class="form-control rounded-input" placeholder="Phone Number *" />
                </div>
                <div class="col-6">
                  <input type="email" class="form-control rounded-input" placeholder="Email Address *" />
                </div>
              </div>
              <div class="mt-2">
                <input class="form-control rounded-input" placeholder="Zip Code *" />
              </div>
              <div class="mt-2">
                <select class="form-select rounded-input">
                  <option selected>How Did You Hear About Us?</option>
                </select>
              </div>
              <div class="mt-2">
                <textarea class="form-control rounded-input" rows="4" placeholder="How Can We Help You?"></textarea>
              </div>
              <div class="mt-2">
                <select class="form-select rounded-input">
                  <option selected>Book An Appointment?</option>
                </select>
              </div>
              <div class="mt-3">
                <button type="button" class="btn btn-danger w-100 btn-cta">START BOOKING NOW</button>
              </div>
            </form>
          </div>
        </div>
      </div>

    </div>
