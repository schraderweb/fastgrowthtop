<link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;600;700&display=swap" rel="stylesheet"/>
<style>
  *, *::before, *::after { box-sizing: border-box; }
  body { font-family: 'Open Sans', sans-serif; margin: 0; padding: 0; }

  /* ── MOBILE TOPBAR — floats over hero image ── */
  .mobile-topbar {
    display: none;
    background: rgba(11, 45, 72, 0.15);     /* same as desktop navbar */
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
    padding: 0 16px;
    height: 56px;
    align-items: center;
    justify-content: space-between;
    position: absolute;                      /* floats over hero */
    top: 0;
    left: 0;
    right: 0;
    z-index: 1100;
    box-shadow: none;
    border-bottom: 1px solid rgba(255,255,255,0.15);
  }

  /* ── HAMBURGER ── */
  .hamburger {
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    display: flex;
    align-items: center;
  }
  .hamburger svg {
    width: 28px;
    height: 28px;
    fill: none;
  }

  /* ── OVERLAY ── */
  .overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,.45);
    z-index: 1199;
  }
  .overlay.active { display: block; }

  /* ── SLIDE-IN DRAWER ── */
  .mobile-drawer {
    position: fixed;
    top: 0;
    left: -320px;
    width: 300px;
    height: 100dvh;
    background: #1b4f82;
    z-index: 1200;
    display: flex;
    flex-direction: column;
    transition: left .3s ease;
    overflow-y: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .mobile-drawer::-webkit-scrollbar { display: none; }
  .mobile-drawer.open { left: 0; }

  /* Drawer header */
  .drawer-header {
    background: #d93025;
    padding: 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-shrink: 0;
  }
  .drawer-logo {
    color: #fff;
    font-size: 1rem;
    font-weight: 700;
    text-decoration: none;
  }
  .close-btn {
    background: none;
    border: none;
    color: #fff;
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
  }
  .close-btn svg {
    width: 22px;
    height: 22px;
    stroke: #fff;
    fill: none;
    stroke-width: 2.5;
    stroke-linecap: round;
  }

  /* CTA buttons */
  .drawer-ctas {
    padding: 12px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    border-bottom: 1px solid rgba(255,255,255,.15);
    flex-shrink: 0;
  }
  .drawer-ctas a {
    display: block;
    text-align: center;
    padding: 11px;
    font-size: .82rem;
    font-weight: 700;
    text-decoration: none;
    border-radius: 3px;
    letter-spacing: .5px;
    text-transform: uppercase;
  }
  .cta-red   { background: #d93025; color: #fff; }
  .cta-white { background: #fff;    color: #1b4f82; }

  /* Nav list */
  .drawer-nav {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .drawer-nav > li { border-bottom: 1px solid rgba(255,255,255,.1); }

  /* Top-level button */
  .drawer-nav > li > .m-nav-btn {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: none;
    border: none;
    color: #fff;
    font-family: 'Open Sans', sans-serif;
    font-size: .9rem;
    font-weight: 600;
    padding: 15px 16px;
    cursor: pointer;
    text-align: left;
    transition: background .2s;
  }
  .drawer-nav > li > .m-nav-btn:hover { background: rgba(255,255,255,.08); }
  .drawer-nav > li.open > .m-nav-btn  { background: rgba(255,255,255,.1); }

  /* Chevron */
  .chevron-icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    stroke: rgba(255,255,255,.85);
    fill: none;
    stroke-width: 2.5;
    stroke-linecap: round;
    stroke-linejoin: round;
    transition: transform .25s;
  }
  .drawer-nav > li.open > .m-nav-btn .chevron-icon {
    transform: rotate(180deg);
  }

  /* Submenu */
  .m-submenu {
    display: none;
    background: #163e67;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .drawer-nav > li.open .m-submenu { display: block; }

  .m-submenu li { border-top: 1px solid rgba(255,255,255,.08); }
  .m-submenu li a {
    display: block;
    color: rgba(255,255,255,.88);
    font-size: .83rem;
    padding: 12px 24px;
    text-decoration: none;
    transition: background .15s;
  }
  .m-submenu li a:hover { background: rgba(255,255,255,.08); color: #fff; }

  /* ── SHOW / HIDE ── */
  @media (max-width: 991px)  { .mobile-topbar { display: flex; } }
  @media (min-width: 992px)  { .mobile-topbar, .mobile-drawer, .overlay { display: none !important; } }
</style>

<!-- ① MOBILE TOPBAR -->
